# LLM Providers (at least one required)
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Google Cloud (for Speech-to-Text)
# Download from Google Cloud Console > Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Default Settings (optional - can also be set via CLI)
DEFAULT_LLM_PROVIDER=claude  # Options: claude, openai
DEFAULT_TIMEZONE=Africa/Cairo
DEFAULT_SCHEDULE_DAY=Saturday
DEFAULT_SCHEDULE_TIME=19:00
